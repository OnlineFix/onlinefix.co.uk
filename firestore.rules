rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Repairs collection
    match /repairs/{repairId} {
      // Only specific admin emails can read and write
      // Add your admin email addresses to this list
      allow read, write: if request.auth != null
        && request.auth.token.email in [
          'onlinerepairbooking@gmail.com',
          'hello@onlinefix.uk'
        ];

      // Public read-only access for tracking page (by repair ID query)
      // Limited to get (single doc) and list (query) - no write access
      allow get, list: if true;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
